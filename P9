#include<stdio.h>
#include<stdlib.h>
#include<time.h>

void selsort(int a[], int n)
{
    int i, j, small, pos, temp;

    for(j = 0; j < n - 1; j++)
    {
        small = a[j];
        pos = j;

        for(i = j + 1; i < n; i++)
        {
            if(a[i] < small)
            {
                small = a[i];
                pos = i;
            }
        }

        temp = a[j];
        a[j] = small;
        a[pos] = temp;
    }
}

int main()
{
    int a[100000], i, n;
    clock_t start, end;
    double dura;

    srand(time(NULL));

    printf("\nEnter the n value:");
    scanf("%d", &n);

    for(i = 0; i < n; i++)
        a[i] = rand() % 10000;

    start = clock();

    selsort(a, n);

    end = clock();

    dura = (double)(end - start) / CLOCKS_PER_SEC;

    printf("\nTime taken is:%lf", dura);

    printf("\nSorted array is:\n");

    for(i = 0; i < n; i++)
        printf("%d ", a[i]);

    return 0;
}
